# --- Supabase (filled in Milestone A2) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=info

# --- AI providers (optional; only the selected provider's key needs to be set) ---
# The Settings.aiApiKeyRef row in the DB selects which of these env vars to read at runtime.
AI_API_KEY_OPENROUTER=
AI_API_KEY_OPENAI=
AI_API_KEY_ANTHROPIC=
AI_API_KEY_GOOGLE=

# --- n8n webhook Basic Auth (optional; used only when processingPath="n8n") ---
# Set both to enable Basic Auth on outbound parse requests to your n8n webhook.
# Leave blank if your webhook is unauthenticated or uses a different auth scheme.
N8N_WEBHOOK_AUTH_USER=
N8N_WEBHOOK_AUTH_PASSWORD=

# --- Hosted-access contact form (homepage "Just want to use it?" section) ---
# Resend → https://resend.com/api-keys (server-only secret)
RESEND_API_KEY=
# hCaptcha → https://dashboard.hcaptcha.com → Sites → Site / Secret Keys
HCAPTCHA_SECRET_KEY=
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
# Sender must be on a domain verified in Resend (e.g., send.digestibleapps.com).
CONTACT_FROM=contact@send.digestibleapps.com
CONTACT_TO=hello@digestibleapps.com
